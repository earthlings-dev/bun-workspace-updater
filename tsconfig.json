// Project config for `bun run typecheck` (tsc --noEmit) and typescript-eslint's project
// service. Extends the strict shared base and includes the WHOLE codebase — `src/`,
// `tests/`, and `eslint.config.ts` — so strict type-checking and type-aware linting cover
// every file. Nothing is exempted from the strict ruleset; tests are type-checked too.
{
  "extends": "./tsconfig.strict.json",
  "include": [
    "src",
    "tests",
    "eslint.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}