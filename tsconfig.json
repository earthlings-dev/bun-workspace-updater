// Project config for `bun run typecheck` (tsc --noEmit). Extends the strict shared
// base and scopes the type-checking program to `src/` plus `eslint.config.ts` (the
// latter so typescript-eslint's project service can type-check the ESLint config
// itself). Tests under `tests/` are run by Bun's test runner (`bun run test`), which
// transpiles rather than type-checks them, so they are not covered by this config.
{
  "extends": "./tsconfig.strict.json",
  "include": [
    "src",
    "eslint.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}